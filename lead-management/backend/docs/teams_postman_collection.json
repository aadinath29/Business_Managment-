{
  "info": {
    "name": "CRM Lead Management - Phase 5 (Teams Module)",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Authentication Helpers",
      "item": [
        {
          "name": "1. Login as Super Admin",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@antigravity.com\",\n  \"password\": \"Admin@123\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/login",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "auth",
                "login"
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const response = pm.response.json();",
                  "if (response.success) {",
                  "    pm.environment.set(\"adminToken\", response.data.accessToken);",
                  "    pm.environment.set(\"tenantId\", response.data.user.tenantId);",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "2. Login as Developer (No Access)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"aarav.mehta@kosqu.com\",\n  \"password\": \"Dev@123\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/login",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "auth",
                "login"
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const response = pm.response.json();",
                  "if (response.success) {",
                  "    pm.environment.set(\"devToken\", response.data.accessToken);",
                  "}"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "Teams",
      "item": [
        {
          "name": "Create Team (Provision Leader)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{adminToken}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"team_name\": \"Spartans CRM Team\",\n  \"branch_id\": \"cccc0000-0000-0000-0000-000000000001\",\n  \"department\": \"CRM Development\",\n  \"leader_name\": \"Leonidas Spartans\",\n  \"leader_email\": \"leonidas@sparta.com\",\n  \"leader_password\": \"LeaderPass123\",\n  \"employee_id\": \"TL_LEO_300\",\n  \"designation\": \"Senior Team Leader\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/teams",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "teams"
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const response = pm.response.json();",
                  "if (response.success) {",
                  "    pm.environment.set(\"testTeamId\", response.data.id);",
                  "    pm.environment.set(\"testLeaderProfileId\", response.data.leader.id);",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "Get Teams List",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{adminToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/teams?page=1&limit=10&department=CRM Development",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "teams"
              ],
              "query": [
                {
                  "key": "page",
                  "value": "1"
                },
                {
                  "key": "limit",
                  "value": "10"
                },
                {
                  "key": "department",
                  "value": "CRM Development"
                }
              ]
            }
          }
        },
        {
          "name": "Get Team by ID",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{adminToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/teams/{{testTeamId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "teams",
                "{{testTeamId}}"
              ]
            }
          }
        },
        {
          "name": "Update Team",
          "request": {
            "method": "PATCH",
            "header": [
