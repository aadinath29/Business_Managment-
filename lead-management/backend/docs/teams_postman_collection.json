                "statistics"
              ]
            }
          }
        },
        {
          "name": "Delete Team (Soft Delete)",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{adminToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/teams/{{testTeamId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "teams",
                "{{testTeamId}}"
              ]
            }
          }
        }
      ]
    },
