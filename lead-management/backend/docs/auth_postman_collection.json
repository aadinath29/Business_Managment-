{
  "info": {
    "name": "CRM Lead Management - Complete API (Auth & Branches)",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Authentication",
      "item": [
        {
          "name": "1. Login (Super Admin)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@antigravity.com\",\n  \"password\": \"Admin@123\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/login",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "auth",
                "login"
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const response = pm.response.json();",
                  "if (response.success) {",
                  "    pm.environment.set(\"accessToken\", response.data.accessToken);",
                  "    pm.environment.set(\"refreshToken\", response.data.refreshToken);",
                  "    pm.environment.set(\"tenantId\", response.data.user.tenantId);",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "2. Login (Developer)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"aarav.mehta@kosqu.com\",\n  \"password\": \"Dev@123\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/login",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "auth",
                "login"
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const response = pm.response.json();",
                  "if (response.success) {",
                  "    pm.environment.set(\"devAccessToken\", response.data.accessToken);",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "3. Get Current User (Me)",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/auth/me",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "auth",
                "me"
              ]
            }
          }
        },
        {
          "name": "4. Refresh Token",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refreshToken\": \"{{refreshToken}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/refresh",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "auth",
                "refresh"
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const response = pm.response.json();",
                  "if (response.success) {",
                  "    pm.environment.set(\"accessToken\", response.data.accessToken);",
                  "    pm.environment.set(\"refreshToken\", response.data.refreshToken);",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "5. Logout",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/auth/logout",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "auth",
                "logout"
              ]
            }
          }
        }
      ]
    },
    {
      "name": "Branches",
      "item": [
        {
          "name": "1. Create Branch (Admin)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"branch_name\": \"Pune Innovation Center\",\n  \"branch_code\": \"PN-IC-009\",\n  \"city\": \"Pune\",\n  \"assigned_target\": 500000,\n  \"health_score\": 90,\n  \"email\": \"pune.ic@kosqu.com\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/branches",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "branches"
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const response = pm.response.json();",
                  "if (response.success) {",
                  "    pm.environment.set(\"branchId\", response.data.id);",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "2. Get All Branches (Admin)",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/branches?page=1&limit=10&search=Innovation",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "branches"
              ],
              "query": [
                {
                  "key": "page",
                  "value": "1"
                },
                {
                  "key": "limit",
                  "value": "10"
                },
                {
                  "key": "search",
                  "value": "Innovation"
                }
              ]
            }
          }
        },
        {
          "name": "3. Get Branch By ID",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/branches/{{branchId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "branches",
                "{{branchId}}"
              ]
            }
          }
        },
        {
          "name": "4. Update Branch (PATCH)",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"branch_name\": \"Pune Innovation Center Updated\",\n  \"assigned_target\": 750000\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/branches/{{branchId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "branches",
                "{{branchId}}"
              ]
            }
          }
        },
        {
          "name": "5. Delete Branch (Soft Delete)",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/branches/{{branchId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "branches",
                "{{branchId}}"
              ]
            }
          }
        },
        {
          "name": "6. Create Branch (Duplicate Code) - Conflict 409",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"branch_name\": \"Duplicate Code Branch\",\n  \"branch_code\": \"KQ001\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/branches",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "branches"
              ]
            }
          }
        },
        {
          "name": "7. Developer Access - Forbidden 403",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{devAccessToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/branches",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "branches"
              ]
            }
          }
        },
        {
          "name": "8. Cross Tenant Access - Mismatch Error",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/branches?tenantId=aaaa1111-1111-1111-1111-111111111111",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "branches"
              ],
              "query": [
                {
                  "key": "tenantId",
                  "value": "aaaa1111-1111-1111-1111-111111111111"
                }
              ]
            }
          }
        }
      ]
    }
  ],
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": []
      }
    },
    {
      "listen": "test",
      "script": {
        "type": "text/javascript",
        "exec": []
      }
    }
  ],
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:5000/api/v1",
      "type": "string"
    }
  ]
}
