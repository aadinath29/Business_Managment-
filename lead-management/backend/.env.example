# Server Configuration
PORT=5000
NODE_ENV=development

# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=your_secure_password
DB_NAME=lead_management_db

# Connection Pool Configuration
DB_POOL_MAX=20
DB_POOL_IDLE_TIMEOUT=30000
DB_POOL_CONN_TIMEOUT=2000

# Authentication Configuration
JWT_SECRET=your_super_secret_access_token_key_here_change_in_production
JWT_REFRESH_SECRET=your_super_secret_refresh_token_key_here_change_in_production
ACCESS_TOKEN_EXPIRY=15m
REFRESH_TOKEN_EXPIRY=7d

# CORS Allowed Origin
CORS_ORIGIN=http://localhost:5173
